# AWS Integration Test Environment Configuration
# This file is used when running tests against AWS-deployed services
# Set AWS_ENV=true environment variable to use this configuration

# Service Endpoints (replace with your actual AWS endpoints)
INGRESS_BASE_URL=https://atlas-itest.example.com
CONTROL_PLANE_BASE_URL=https://control-plane-itest.example.com
PROMETHEUS_BASE_URL=https://prometheus-itest.example.com

# Test Data Configuration
TEST_TENANT_ID=tenant-aws-itest-001

# HTTP Client Configuration (longer timeouts for network latency)
HTTP_TIMEOUT_SECONDS=10
RETRY_ATTEMPTS=5
