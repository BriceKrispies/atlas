{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog.family_published.v1",
  "title": "CatalogFamilyPublishedEventPayload",
  "description": "Payload for StructuredCatalog.FamilyPublished domain events",
  "type": "object",
  "additionalProperties": false,
  "required": ["familyKey", "familyId", "revisionNumber", "publishedAt"],
  "properties": {
    "familyKey": {
      "type": "string",
      "minLength": 1
    },
    "familyId": {
      "type": "string",
      "format": "uuid"
    },
    "revisionNumber": {
      "type": "integer",
      "minimum": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
