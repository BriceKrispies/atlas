{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.example.com/schemas/event-envelope.v1.json",
  "title": "EventEnvelope",
  "description": "Common envelope for all domain, UI intent, system, and audit events",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "schemaId",
    "schemaVersion",
    "occurredAt",
    "tenantId",
    "correlationId",
    "idempotencyKey",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "description": "Unique event identifier (UUID recommended)",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "description": "Event type in format Domain.Event",
      "pattern": "^[A-Za-z0-9]+\\.[A-Za-z0-9]+$",
      "examples": [
        "ContentPages.PageCreated",
        "Workflow.TaskCompleted"
      ]
    },
    "schemaId": {
      "type": "string",
      "description": "Schema identifier for payload validation",
      "pattern": "^[a-z0-9.]+$",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "integer",
      "description": "Schema version number",
      "minimum": 1
    },
    "occurredAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when event occurred",
      "format": "date-time"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant context for this event",
      "minLength": 1
    },
    "principalId": {
      "type": "string",
      "description": "Principal who initiated this event (optional for system events)"
    },
    "userId": {
      "type": "string",
      "description": "User ID if applicable (optional)"
    },
    "correlationId": {
      "type": "string",
      "description": "Request correlation ID for tracing",
      "minLength": 1
    },
    "causationId": {
      "type": "string",
      "description": "ID of the causal event (optional)"
    },
    "idempotencyKey": {
      "type": "string",
      "description": "Deduplication key for idempotent processing",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload"
    }
  }
}
