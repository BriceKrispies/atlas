{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.example.com/schemas/ui-bundle.v1.json",
  "title": "UIBundle",
  "description": "UI Bundle artifact descriptor for versioned frontend code packages. See specs/crosscut/ui.md for full specification.",
  "type": "object",
  "required": ["bundleId", "version", "displayName", "platformCompatibility", "status", "provides"],
  "additionalProperties": false,
  "properties": {
    "bundleId": {
      "type": "string",
      "description": "Unique identifier for the bundle (kebab-case)",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1,
      "examples": ["atlas-ui-standard", "atlas-ui-admin", "tenant-custom-v2"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the bundle",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.0.0", "2.3.1"]
    },
    "displayName": {
      "type": "string",
      "description": "Human-readable name for the bundle",
      "minLength": 1,
      "examples": ["Atlas Standard UI", "Atlas Admin Portal"]
    },
    "description": {
      "type": "string",
      "description": "Optional description of the bundle's purpose or contents",
      "minLength": 1
    },
    "platformCompatibility": {
      "type": "object",
      "description": "Platform API version compatibility range",
      "required": ["minVersion"],
      "additionalProperties": false,
      "properties": {
        "minVersion": {
          "type": "string",
          "description": "Minimum platform version required (inclusive)",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "maxVersion": {
          "type": "string",
          "description": "Maximum platform version supported (exclusive). If omitted, no upper bound.",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the bundle",
      "enum": ["draft", "published", "deprecated", "archived"]
    },
    "provides": {
      "type": "object",
      "description": "Capabilities provided by this bundle",
      "required": ["routes"],
      "additionalProperties": false,
      "properties": {
        "routes": {
          "type": "array",
          "description": "Route identifiers provided by this bundle",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "widgets": {
          "type": "array",
          "description": "Widget identifiers provided by this bundle",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "themes": {
          "type": "array",
          "description": "Theme identifiers provided by this bundle",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "description": "Optional entrypoint paths for bundle assets",
      "additionalProperties": false,
      "properties": {
        "main": {
          "type": "string",
          "description": "Main JavaScript entrypoint path",
          "minLength": 1
        },
        "styles": {
          "type": "string",
          "description": "Main CSS entrypoint path",
          "minLength": 1
        }
      }
    },
    "integrity": {
      "type": "object",
      "description": "Optional integrity metadata for verification",
      "additionalProperties": false,
      "properties": {
        "checksum": {
          "type": "string",
          "description": "Content hash (e.g., SHA-256)",
          "pattern": "^[a-f0-9]+$",
          "minLength": 64,
          "maxLength": 64
        },
        "algorithm": {
          "type": "string",
          "description": "Hash algorithm used",
          "enum": ["sha256"]
        }
      }
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of bundle creation",
      "format": "date-time"
    },
    "publishedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the bundle was published",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "published" } }
      },
      "then": {
        "required": ["publishedAt"]
      }
    }
  ],
  "$comment": "This schema enforces INV-UI-01 (platformCompatibility required) and INV-UI-03 (routes required in provides) from specs/crosscut/ui.md."
}
