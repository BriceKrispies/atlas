{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.dev/schemas/search_query.v1.json",
  "title": "SearchQuery",
  "description": "Search query with execution context for permission filtering",
  "type": "object",
  "required": ["query", "executionContext"],
  "additionalProperties": false,
  "properties": {
    "query": {
      "type": "string",
      "description": "Search query text"
    },
    "filters": {
      "type": "object",
      "description": "Optional filters (documentType, field values, etc.)",
      "additionalProperties": true
    },
    "executionContext": {
      "type": "object",
      "required": ["tenantId", "principalId"],
      "additionalProperties": false,
      "properties": {
        "tenantId": {
          "type": "string",
          "minLength": 1,
          "description": "Tenant context (ensures tenant isolation)"
        },
        "principalId": {
          "type": "string",
          "minLength": 1,
          "description": "Principal making the request (for permission filtering)"
        },
        "correlationId": {
          "type": "string",
          "description": "Optional correlation ID for tracing"
        }
      }
    }
  }
}
