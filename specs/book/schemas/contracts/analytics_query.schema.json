{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.dev/schemas/analytics_query.v1.json",
  "title": "AnalyticsQuery",
  "description": "Time-bucketed analytics query with dimension grouping",
  "type": "object",
  "required": ["querySpec", "executionContext"],
  "additionalProperties": false,
  "properties": {
    "querySpec": {
      "type": "object",
      "required": ["eventType", "timeRange", "aggregationType", "bucketSize"],
      "additionalProperties": false,
      "properties": {
        "eventType": {
          "type": "string",
          "minLength": 1,
          "description": "Event type to query"
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Dimensions to group by (e.g., ['status', 'region'])"
        },
        "timeRange": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "aggregationType": {
          "type": "string",
          "enum": ["count", "sum", "avg", "min", "max"],
          "description": "How to aggregate metrics within buckets"
        },
        "metricName": {
          "type": ["string", "null"],
          "description": "Metric to aggregate (null for count aggregation)"
        },
        "bucketSize": {
          "type": "string",
          "pattern": "^[0-9]+(s|m|h|d)$",
          "description": "Time bucket size (e.g., '5m', '1h', '1d')"
        }
      }
    },
    "executionContext": {
      "type": "object",
      "required": ["tenantId", "principalId"],
      "additionalProperties": false,
      "properties": {
        "tenantId": {
          "type": "string",
          "minLength": 1,
          "description": "Tenant context (ensures tenant isolation)"
        },
        "principalId": {
          "type": "string",
          "minLength": 1,
          "description": "Principal making the request"
        },
        "correlationId": {
          "type": "string",
          "description": "Optional correlation ID for tracing"
        }
      }
    }
  }
}
