{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.example.com/schemas/policy-ast.v1.json",
  "title": "PolicyAST",
  "description": "Abstract syntax tree for ABAC policy expressions",
  "definitions": {
    "policyExpression": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "literal"
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "left", "right"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "equals"
            },
            "left": {
              "$ref": "#/definitions/policyValue"
            },
            "right": {
              "$ref": "#/definitions/policyValue"
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "operand"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "not"
            },
            "operand": {
              "$ref": "#/definitions/policyExpression"
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "operands"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "and"
            },
            "operands": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/policyExpression"
              },
              "minItems": 1
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "operands"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "or"
            },
            "operands": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/policyExpression"
              },
              "minItems": 1
            }
          }
        }
      ]
    },
    "policyValue": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "literal"
            },
            "value": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "path", "source"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "attribute"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "enum": ["principal", "resource", "environment"]
            }
          }
        }
      ]
    },
    "policyRule": {
      "type": "object",
      "required": ["ruleId", "effect", "conditions"],
      "additionalProperties": false,
      "properties": {
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny"]
        },
        "conditions": {
          "$ref": "#/definitions/policyExpression"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["policyId", "tenantId", "rules", "version", "status"],
      "additionalProperties": false,
      "properties": {
        "policyId": {
          "type": "string",
          "minLength": 1
        },
        "tenantId": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/policyRule"
          }
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"]
        }
      }
    }
  },
  "$ref": "#/definitions/policy"
}
