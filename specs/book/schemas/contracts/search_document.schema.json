{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas-platform.dev/schemas/search_document.v1.json",
  "title": "SearchDocument",
  "description": "Indexed document in search engine with permission attributes",
  "type": "object",
  "required": ["documentId", "documentType", "tenantId", "fields"],
  "additionalProperties": false,
  "properties": {
    "documentId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the document"
    },
    "documentType": {
      "type": "string",
      "minLength": 1,
      "description": "Type of document (e.g., Page, Widget, User)"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant this document belongs to (MUST be set for tenant isolation)"
    },
    "fields": {
      "type": "object",
      "description": "Searchable fields specific to document type",
      "additionalProperties": true
    },
    "permissionAttributes": {
      "oneOf": [
        {
          "type": "null",
          "description": "Public within tenant (no permission filtering)"
        },
        {
          "type": "object",
          "required": ["allowedPrincipals"],
          "additionalProperties": false,
          "properties": {
            "allowedPrincipals": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "description": "Whitelist of principals who can view this document"
            }
          }
        }
      ],
      "description": "Permission filtering attributes; null means public within tenant"
    }
  }
}
