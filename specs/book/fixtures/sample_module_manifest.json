{
  "$schema": "../module_manifest.schema.json",
  "moduleId": "content-pages",
  "displayName": "Content Pages",
  "version": "1.0.0",
  "actions": [
    {
      "actionId": "ContentPages.Page.Create",
      "resourceType": "Page",
      "verb": "create",
      "auditLevel": "SENSITIVE"
    },
    {
      "actionId": "ContentPages.Page.Search",
      "resourceType": "Page",
      "verb": "search",
      "auditLevel": "INFO"
    },
    {
      "actionId": "Analytics.Query",
      "resourceType": "AnalyticsDashboard",
      "verb": "query",
      "auditLevel": "INFO"
    }
  ],
  "resources": [
    {
      "resourceType": "Page",
      "ownership": "module"
    },
    {
      "resourceType": "WidgetInstance",
      "ownership": "module"
    }
  ],
  "events": [
    {
      "eventType": "ContentPages.PageCreated",
      "category": "DOMAIN",
      "schemaId": "domain.contentpages.page.created.v1",
      "compatibility": "BACKWARD"
    },
    {
      "eventType": "ContentPages.WidgetInstanceAdded",
      "category": "DOMAIN",
      "schemaId": "domain.contentpages.widgetinstance.added.v1",
      "compatibility": "BACKWARD"
    }
  ],
  "projections": [
    {
      "projectionName": "RenderPageModel",
      "inputEvents": [
        "ContentPages.PageCreated",
        "ContentPages.WidgetInstanceAdded",
        "ContentPages.WidgetInstanceSettingsUpdated"
      ],
      "outputModel": "render_ready_page_json",
      "rebuildable": true
    }
  ],
  "jobs": [
    {
      "jobType": "ContentPages.RebuildRenderPageModel",
      "schemaId": "job.contentpages.rebuild.renderpage.v1",
      "triggeredBy": ["ContentPages.WidgetInstanceSettingsUpdated"],
      "idempotencyKey": "{tenantId}:{pageId}:{projectionVersion}"
    }
  ],
  "cacheArtifacts": [
    {
      "artifactId": "RenderPageModel",
      "varyBy": ["TENANT", "LOCALE"],
      "ttlSeconds": 300,
      "tags": ["Tenant:{tenantId}", "Page:{pageId}"],
      "privacy": "TENANT"
    }
  ],
  "migrations": [],
  "uiRoutes": [],
  "capabilities": ["content-management"]
}
