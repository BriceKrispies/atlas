{
  "bundleId": "atlas-ui-standard",
  "version": "0.1.0",
  "displayName": "Atlas Standard UI",
  "description": "First-party baseline bundle: announcements, messaging, and spreadsheet uploader widgets plus one-column and two-column page templates.",
  "platformCompatibility": {
    "minVersion": "0.1.0"
  },
  "status": "draft",
  "provides": {
    "routes": ["sandbox"],
    "widgets": [
      "content.announcements",
      "comms.messaging",
      "import.spreadsheet-uploader"
    ],
    "templates": [
      "template.one-column",
      "template.two-column",
      "template.three-column",
      "template.header-main-footer",
      "template.hero-and-grid",
      "template.dashboard-tiles"
    ]
  },
  "entrypoints": {
    "main": "src/index.js"
  }
}
