# Control Plane Database Configuration
# This file works with both podman-compose (default) and docker-compose
# To use docker: export CONTAINER_RUNTIME=docker

# Postgres Configuration
POSTGRES_DB=control_plane
POSTGRES_USER=atlas_platform
POSTGRES_PASSWORD=local_dev_password
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# Connection URL for application
CONTROL_PLANE_DB_URL=postgres://atlas_platform:local_dev_password@localhost:5432/control_plane
CONTROL_PLANE_DB_SCHEMA=control_plane
CONTROL_PLANE_ENABLED=true

# Tenant ID (used during bootstrap)
TENANT_ID=tenant-001

# Keycloak Configuration (Identity Provider)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8081

# OIDC Configuration (for local dev with Keycloak)
# Issuer URL must match the 'iss' claim in tokens minted by Keycloak
# Default realm is 'atlas' - create this realm in Keycloak admin console
OIDC_ISSUER_URL=http://keycloak:8080/realms/atlas
OIDC_AUDIENCE=atlas-ingress

# Ingress Configuration (for compose.dev.yml)
INGRESS_PORT=3000
RUST_LOG=info,atlas_platform_ingress=debug
