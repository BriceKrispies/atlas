{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "paths": {
      "@atlas/core": ["./packages/core/src/index.ts"],
      "@atlas/core/*": ["./packages/core/src/*"],
      "@atlas/design": ["./packages/design/src/index.ts"],
      "@atlas/design/*": ["./packages/design/src/*"],
      "@atlas/api-client": ["./packages/api-client/src/index.ts"],
      "@atlas/api-client/*": ["./packages/api-client/src/*"],
      "@atlas/widget-host": ["./packages/widget-host/src/index.ts"],
      "@atlas/widget-host/*": ["./packages/widget-host/src/*"],
      "@atlas/widgets": ["./packages/widgets/src/index.ts"],
      "@atlas/widgets/*": ["./packages/widgets/src/*"],
      "@atlas/page-templates": ["./packages/page-templates/src/index.ts"],
      "@atlas/page-templates/*": ["./packages/page-templates/src/*"],
      "@atlas/test-fixtures": ["./packages/test-fixtures/src/index.ts"],
      "@atlas/test-fixtures/*": ["./packages/test-fixtures/src/*"],
      "@atlas/test-state": ["./packages/test-state/src/index.ts"],
      "@atlas/test-state/*": ["./packages/test-state/src/*"],
      "@atlas/eslint-plugin-widgets": ["./packages/eslint-plugin-atlas-widgets/src/index.ts"],
      "@atlas/bundle-standard": ["./bundles/standard/src/index.ts"],
      "@atlas/bundle-standard/*": ["./bundles/standard/src/*"],
      "@atlas/platform-core": ["./packages/platform-core/src/index.ts"],
      "@atlas/platform-core/*": ["./packages/platform-core/src/*"],
      "@atlas/schemas": ["./packages/schemas/src/index.ts"],
      "@atlas/schemas/*": ["./packages/schemas/src/*"],
      "@atlas/ports": ["./ports/src/index.ts"],
      "@atlas/ports/*": ["./ports/src/*"],
      "@atlas/contract-tests": ["./packages/contract-tests/src/index.ts"],
      "@atlas/contract-tests/*": ["./packages/contract-tests/src/*"],
      "@atlas/adapter-idb": ["./adapters/idb/src/index.ts"],
      "@atlas/adapter-idb/*": ["./adapters/idb/src/*"],
      "@atlas/adapter-node": ["./adapters/node/src/index.ts"],
      "@atlas/adapter-node/*": ["./adapters/node/src/*"],
      "@atlas/adapter-policy-stub": ["./adapters/policy-stub/src/index.ts"],
      "@atlas/adapter-policy-stub/*": ["./adapters/policy-stub/src/*"],
      "@atlas/adapter-policy-cedar": ["./adapters/policy-cedar/src/index.ts"],
      "@atlas/adapter-policy-cedar/*": ["./adapters/policy-cedar/src/*"],
      "@atlas/ingress": ["./packages/ingress/src/index.ts"],
      "@atlas/ingress/*": ["./packages/ingress/src/*"],
      "@atlas/catalog": ["./modules/catalog/src/index.ts"],
      "@atlas/catalog/*": ["./modules/catalog/src/*"],
      "@atlas/authz": ["./modules/authz/src/index.ts"],
      "@atlas/authz/*": ["./modules/authz/src/*"],
      "@atlas/metrics": ["./packages/metrics/src/index.ts"],
      "@atlas/metrics/*": ["./packages/metrics/src/*"],
      "@atlas/content-pages": ["./modules/content-pages/src/index.ts"],
      "@atlas/content-pages/*": ["./modules/content-pages/src/*"],
      "@atlas/wasm-host": ["./packages/wasm-host/src/index.ts"],
      "@atlas/wasm-host/*": ["./packages/wasm-host/src/*"],
      "@atlas/server": ["./apps/server/src/main.ts"],
      "@atlas/server/*": ["./apps/server/src/*"]
    }
  },
  "include": [
    "global.d.ts",
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "modules/*/src/**/*.ts",
    "modules/*/test/**/*.ts",
    "adapters/*/src/**/*.ts",
    "adapters/*/test/**/*.ts",
    "ports/src/**/*.ts",
    "ports/test/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/tests/**/*.ts",
    "apps/*/vite.config.ts",
    "apps/*/playwright.config.ts",
    "bundles/*/src/**/*.ts",
    "bundles/*/test/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts",
    "playwright.itest.config.ts",
    "eslint.config.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/test-results",
    "**/playwright-report"
  ]
}
